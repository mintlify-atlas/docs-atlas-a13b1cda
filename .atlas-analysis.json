  "keyFeatures": [
    "O(log n) performance for count, sum, and aggregation queries",
    "Support for arbitrary Convex values as sort keys",
    "Grouping data with prefix bounds and multi-part keys",
    "Namespace isolation for high-throughput partitioned data",
    "Fully reactive with automatic UI updates",
    "Transactional consistency with atomic operations",
    "Batch operations for improved performance",
    "Integration with Convex tables via triggers"
  ],
